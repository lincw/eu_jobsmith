ANTHROPIC_API_KEY=sk-ant-xxxxx
# 選用：開啟 LangSmith 追蹤
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_xxxxx
# LANGSMITH_PROJECT=tw-job-copilot
# 公司情報搜尋（選用）：claude_cli 後端會用內建 WebSearch/WebFetch 上網查證，免此金鑰。
# 僅在用 anthropic API 後端、又想要附來源的網路查證時才需要 Tavily；
# 未設且非 CLI 後端 → 改用 LLM 一般知識並標示資料有限。
# TAVILY_API_KEY=tvly-xxxxx
# LLM 後端：claude_cli（預設，Claude Code CLI 訂閱）/ codex_cli（Codex CLI 訂閱）/ anthropic（API 金鑰）
# CLI 後端免 API key、吃本機訂閱；可在 UI 右上角即時切換
LLM_BACKEND=claude_cli
